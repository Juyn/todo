#!/usr/bin/env python3
"""Terminal TODO list with persistent storage and keyboard navigation."""

import curses
import json
import os
import re
import sys
from pathlib import Path

DATA_FILE = Path.home() / ".local" / "share" / "todo" / "tasks.json"


def load_tasks():
    if DATA_FILE.exists():
        with open(DATA_FILE) as f:
            return json.load(f)
    return []


def save_tasks(tasks):
    DATA_FILE.parent.mkdir(parents=True, exist_ok=True)
    with open(DATA_FILE, "w") as f:
        json.dump(tasks, f, indent=2)


def parse_group(text):
    """Extract group name from [Group] prefix. Returns (group, display_text)."""
    m = re.match(r'^\[([^\]]+)\]\s*', text)
    if m:
        return m.group(1), text[m.end():]
    return None, text


def grouped_display(tasks):
    """Build display lines: group headers + tasks, pending first, done last per group.
    Returns list of (type, data) where type is 'header' or 'task'."""
    # Collect groups preserving order of first appearance
    groups = {}
    no_group = []
    for t in tasks:
        group, _ = parse_group(t["text"])
        if group:
            groups.setdefault(group, []).append(t)
        else:
            no_group.append(t)

    def sort_tasks(lst):
        pending = [t for t in lst if not t["done"]]
        done = [t for t in lst if t["done"]]
        return pending + done

    lines = []
    # Ungrouped tasks first
    for t in sort_tasks(no_group):
        lines.append(("task", t))
    # Then each group
    for group_name, group_tasks in groups.items():
        sorted_group = sort_tasks(group_tasks)
        lines.append(("spacer", None))
        lines.append(("header", group_name))
        for t in sorted_group:
            lines.append(("task", t))
    return lines


def main(stdscr):
    curses.curs_set(0)
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_GREEN, -1)   # done
    curses.init_pair(2, curses.COLOR_WHITE, -1)    # pending
    curses.init_pair(3, curses.COLOR_BLACK, curses.COLOR_WHITE)  # selected
    curses.init_pair(4, curses.COLOR_YELLOW, -1)   # header
    curses.init_pair(5, curses.COLOR_RED, -1)       # delete
    curses.init_pair(6, curses.COLOR_CYAN, -1)      # help

    stdscr.keypad(True)
    curses.set_escdelay(25)

    tasks = load_tasks()
    cursor = 0
    input_mode = None  # None, "add", or "edit"
    new_text = ""
    text_cursor = 0
    message = ""
    message_color = 1
    scroll_offset = 0

    while True:
        stdscr.erase()
        h, w = stdscr.getmaxyx()

        # Header
        header = " TODO "
        try:
            stdscr.addnstr(0, 0, "─" * w, w - 1, curses.color_pair(4))
            stdscr.addnstr(0, max(0, (w - len(header)) // 2), header, w - 1, curses.color_pair(4) | curses.A_BOLD)
        except curses.error:
            pass

        # Help bar
        help_text = "↑↓ space a e d q"
        try:
            stdscr.addnstr(1, max(0, (w - len(help_text)) // 2), help_text, w - 1, curses.color_pair(6))
        except curses.error:
            pass

        lines = grouped_display(tasks)
        # Build task index: map task positions to line positions
        task_indices = [i for i, (typ, _) in enumerate(lines) if typ == "task"]

        # Clamp cursor
        if task_indices:
            cursor = max(0, min(cursor, len(task_indices) - 1))

        list_start = 3
        max_visible = h - list_start - 2

        if max_visible < 1:
            max_visible = 1

        # Scroll based on the line index of the current task
        if task_indices:
            cursor_line = task_indices[cursor]
        else:
            cursor_line = 0

        if cursor_line < scroll_offset:
            scroll_offset = cursor_line
        if cursor_line >= scroll_offset + max_visible:
            scroll_offset = cursor_line - max_visible + 1

        if not lines:
            try:
                stdscr.addnstr(list_start + 1, 2, "Press 'a' to add a task.", w - 3, curses.color_pair(6))
            except curses.error:
                pass
        else:
            for i in range(scroll_offset, min(len(lines), scroll_offset + max_visible)):
                row = list_start + (i - scroll_offset)
                typ, data = lines[i]

                if typ == "spacer":
                    continue
                elif typ == "header":
                    header_line = f" ── {data} ──"
                    if len(header_line) > w - 1:
                        header_line = header_line[:w - 4] + "..."
                    try:
                        stdscr.addnstr(row, 0, header_line, w - 1, curses.color_pair(4) | curses.A_BOLD)
                    except curses.error:
                        pass
                else:
                    task = data
                    is_selected = (i in task_indices and task_indices.index(i) == cursor)
                    _, display_text = parse_group(task["text"])

                    check = "[x]" if task["done"] else "[ ]"
                    text = display_text
                    if task["done"]:
                        text = "".join(c + "\u0336" for c in text)

                    line = f"  {check} {text}"
                    if len(line) > w - 1:
                        line = line[:w - 4] + "..."

                    if is_selected:
                        attr = curses.color_pair(3) | curses.A_BOLD
                    elif task["done"]:
                        attr = curses.color_pair(1)
                    else:
                        attr = curses.color_pair(2)

                    try:
                        stdscr.addstr(row, 0, line.ljust(w - 1), attr)
                    except curses.error:
                        pass

            # Scroll indicator
            if len(lines) > max_visible:
                indicator = f" [{scroll_offset + 1}-{min(scroll_offset + max_visible, len(lines))}/{len(lines)}]"
                try:
                    stdscr.addstr(list_start + max_visible, w - len(indicator) - 1, indicator,
                                  curses.color_pair(6))
                except curses.error:
                    pass

        # Bottom area: input or message
        bottom = h - 1
        if input_mode:
            curses.curs_set(1)
            prompt = " + " if input_mode == "add" else " ~ "
            try:
                stdscr.addstr(bottom, 0, prompt, curses.color_pair(4) | curses.A_BOLD)
                stdscr.addstr(bottom, len(prompt), new_text[:w - len(prompt) - 1])
                stdscr.move(bottom, len(prompt) + text_cursor)
            except curses.error:
                pass
        else:
            curses.curs_set(0)
            if message:
                try:
                    stdscr.addstr(bottom, 1, message[:w - 2], curses.color_pair(message_color))
                except curses.error:
                    pass

        stdscr.refresh()

        try:
            key = stdscr.get_wch()
        except curses.error:
            continue

        # Normalize: convert int char codes to str for uniform handling
        if isinstance(key, int) and 0 < key < 256:
            key = chr(key)

        if input_mode:
            if isinstance(key, str):
                if key == "\n":
                    if new_text.strip():
                        if input_mode == "add":
                            tasks.append({"text": new_text.strip(), "done": False})
                            save_tasks(tasks)
                            message = f"Added: {new_text.strip()}"
                            message_color = 1  # green
                        elif input_mode == "edit":
                            edit_lines = grouped_display(tasks)
                            edit_ti = [i for i, (t, _) in enumerate(edit_lines) if t == "task"]
                            if cursor < len(edit_ti):
                                _, task_ref = edit_lines[edit_ti[cursor]]
                                task_ref["text"] = new_text.strip()
                                save_tasks(tasks)
                                message = f"Edited: {new_text.strip()}"
                                message_color = 1  # green
                    input_mode = None
                    new_text = ""
                    text_cursor = 0
                elif key == "\x1b":
                    input_mode = None
                    new_text = ""
                    text_cursor = 0
                    message = ""
                elif key in ("\x7f", "\b"):
                    if text_cursor > 0:
                        new_text = new_text[:text_cursor - 1] + new_text[text_cursor:]
                        text_cursor -= 1
                elif key.isprintable():
                    new_text = new_text[:text_cursor] + key + new_text[text_cursor:]
                    text_cursor += 1
            elif isinstance(key, int):
                if key == curses.KEY_BACKSPACE:
                    if text_cursor > 0:
                        new_text = new_text[:text_cursor - 1] + new_text[text_cursor:]
                        text_cursor -= 1
                elif key == curses.KEY_LEFT:
                    if text_cursor > 0:
                        text_cursor -= 1
                elif key == curses.KEY_RIGHT:
                    if text_cursor < len(new_text):
                        text_cursor += 1
                elif key == curses.KEY_HOME:
                    text_cursor = 0
                elif key == curses.KEY_END:
                    text_cursor = len(new_text)
                elif key == curses.KEY_DC:  # Delete key
                    if text_cursor < len(new_text):
                        new_text = new_text[:text_cursor] + new_text[text_cursor + 1:]
            continue

        def current_task():
            if task_indices and cursor < len(task_indices):
                _, t = lines[task_indices[cursor]]
                return t
            return None

        if isinstance(key, str):
            if key in ("q", "Q"):
                break
            elif key == "a":
                input_mode = "add"
                new_text = ""
                text_cursor = 0
                message = ""
            elif key == "e" and current_task():
                input_mode = "edit"
                new_text = current_task()["text"]
                text_cursor = len(new_text)
                message = ""
            elif key == " " and current_task():
                ct = current_task()
                ct["done"] = not ct["done"]
                save_tasks(tasks)
                message = ""
            elif key == "d" and current_task():
                removed = current_task()
                tasks = [t for t in tasks if t is not removed]
                save_tasks(tasks)
                cursor = min(cursor, max(0, len([t for t in tasks]) - 1))
                message = f"Deleted: {removed['text']}"
                message_color = 5  # red
            elif key == "j":
                if task_indices and cursor < len(task_indices) - 1:
                    cursor += 1
            elif key == "k":
                if cursor > 0:
                    cursor -= 1

        elif isinstance(key, int):
            if key == curses.KEY_DOWN:
                if task_indices and cursor < len(task_indices) - 1:
                    cursor += 1
            elif key == curses.KEY_UP:
                if cursor > 0:
                    cursor -= 1


if __name__ == "__main__":
    # Quick add from CLI: todo add "my task"
    if len(sys.argv) >= 3 and sys.argv[1] == "add":
        text = " ".join(sys.argv[2:])
        tasks = load_tasks()
        tasks.append({"text": text, "done": False})
        save_tasks(tasks)
        print(f"✓ {text}")
        sys.exit(0)

    # Quick list: todo list
    if len(sys.argv) == 2 and sys.argv[1] == "list":
        tasks = load_tasks()
        lines = grouped_display(tasks)
        if not lines:
            print("No tasks.")
        for typ, data in lines:
            if typ == "spacer":
                continue
            elif typ == "header":
                print(f"\n ── {data} ──")
            else:
                check = "x" if data["done"] else " "
                _, display_text = parse_group(data["text"])
                text = display_text
                if data["done"]:
                    text = "".join(c + "\u0336" for c in text)
                print(f"  [{check}] {text}")
        sys.exit(0)

    curses.wrapper(main)
